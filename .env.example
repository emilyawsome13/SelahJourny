PORT=3000
# On Render, set APP_BASE_URL to your public service URL.
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-session-secret
# On Render, point these at your mounted persistent disk, for example:
# DATA_DIR=/var/data/data
# EMAIL_DIR=/var/data/emails
DATA_DIR=./data
EMAIL_DIR=./emails
EMAIL_FROM=Selah <welcome@yourdomain.com>
# Optional: enable OpenAI-backed AI Studio responses. Without this, Selah uses
# the built-in server fallback so the app still works locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
BIBLE_API_BASE_URL=https://bible.helloao.org
# SMTP_HOST must be a mail server hostname, not an email address.
# For Gmail, use smtp.gmail.com and an app password for SMTP_PASS.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
